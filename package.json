{
  "name": "react-native-goodcharts-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "pnpm --filter react-native-goodcharts build",
    "type-check": "pnpm --filter react-native-goodcharts type-check",
    "lint": "biome check .",
    "test": "jest --runInBand",
    "bench": "tsx benchmarks/render-time.ts",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "pack:dry-run": "pnpm --filter react-native-goodcharts build && pnpm --filter react-native-goodcharts exec npm pack --dry-run",
    "docs:start": "pnpm --filter docs start",
    "example:start": "pnpm --filter example start"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "2.29.2",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/jest": "29.5.14",
    "@types/react": "18.3.12",
    "@types/react-native": "0.73.0",
    "jest": "29.7.0",
    "react-test-renderer": "18.3.1",
    "ts-jest": "29.2.6",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
